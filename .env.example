# ─────────────────────────────────────────────────────
# Local development  (used by Docker / docker-compose)
# ─────────────────────────────────────────────────────
# Copy this file to .env and customise for your
# environment.  On production the .env file is
# deployed separately (never committed to git).
# ─────────────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=matrimony
DB_USERNAME=matrimony_user
DB_PASSWORD=matrimony_pass

APP_ENV=local
APP_DEBUG=true
APP_URL=
APP_TIMEZONE=Asia/Kolkata

MAIL_DRIVER=log
