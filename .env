# ─────────────────────────────────────────────────────
# Local development  (used by Docker / docker-compose)
# ─────────────────────────────────────────────────────
# Copy this file to .env and customise for your
# environment.  On production the .env file is
# deployed separately (never committed to git).
# Instead, set these variables via the hosting
# platform's environment configuration (Heroku
# Config Vars, Docker --env, etc.).
#
# All keys listed here are read by the app at
# runtime via getenv().  Remove any you don't
# need; the app will use server-supplied values.
# ─────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u814177917_matrimony
DB_USERNAME=u814177917_matrimony
